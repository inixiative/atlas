{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "baseUrl": ".",
    "paths": {
      "@inixiative/atlas": ["./src/index.ts"],
      "@inixiative/atlas/config": ["./src/config/defineConfig.ts"]
    },
    "types": ["@types/bun"]
  },
  "include": ["src", "bin", "test"]
}
